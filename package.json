{
  "name": "telegram-md",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "compile": "tsc --noEmit && npm run compile --workspaces --if-present",
    "lint": "eslint .",
    "lint:ci": "DEBUG=eslint:eslint eslint .",
    "prettier": "prettier --write '**/*.(ts|js|md|json)'",
    "prettier:ci": "prettier --check '**/*.(ts|js|md|json)'",
    "test": "vitest run --coverage --coverage.include='src/**/*.ts'",
    "test:ci": "vitest run",
    "test:codecov": "npx vitest run --coverage --coverage.include='src/**/*.ts'"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.2",
    "@vlad-iakovlev/eslint-config": "^1.0.0",
    "eslint": "^9.39.4",
    "jiti": "^2.6.1",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
