{
  "name": "telegram-md",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "changeset:publish": "npm run build && changeset publish",
    "changeset:version": "changeset version && npm install",
    "compile": "tsc --noEmit && npm run compile --workspaces --if-present",
    "lint": "eslint .",
    "lint:ci": "DEBUG=eslint:eslint eslint .",
    "prettier": "prettier --write '**/*.(ts|js|md|json)'",
    "prettier:ci": "prettier --check '**/*.(ts|js|md|json)'",
    "test": "vitest run --coverage --coverage.include='packages/*/src/**/*.ts'",
    "test:ci": "vitest run",
    "test:codecov": "vitest run --coverage --coverage.include='packages/*/src/**/*.ts'"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@napi-rs/wasm-runtime": "^1.1.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "@vlad-iakovlev/eslint-config": "^1.2.0",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
